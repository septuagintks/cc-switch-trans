{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "macos-arm64-release",
      "displayName": "macOS 26 arm64 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "26.0",
        "CMAKE_OSX_SYSROOT": "macosx",
        "CCS_TRANS_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "macos-arm64-warning",
      "displayName": "macOS 26 arm64 warnings as errors",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-macos-warning",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "26.0",
        "CMAKE_OSX_SYSROOT": "macosx",
        "CCS_TRANS_WARNINGS_AS_ERRORS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos-arm64-release",
      "configurePreset": "macos-arm64-release"
    },
    {
      "name": "macos-arm64-warning",
      "configurePreset": "macos-arm64-warning"
    }
  ],
  "testPresets": [
    {
      "name": "macos-arm64-release",
      "configurePreset": "macos-arm64-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-arm64-warning",
      "configurePreset": "macos-arm64-warning",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
